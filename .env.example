SPRING_PROFILES_ACTIVE=default

AGENT_BASE_URL=http://python-agent:8000

MONGO_URI=mongodb://mongo:27017
MONGO_DB=engineering_copilot

# ---------------------------------------------------------------------------
# Auth – Java API
# ---------------------------------------------------------------------------
# JWT_SECRET: required. Must be at least 32 characters.
# Generate a strong value with:  openssl rand -hex 32
JWT_SECRET=96a283a14d225ba24ac051a8c80b83530a07cc4283e2f75b8bb738f74de721f9

# JWT token lifetime in milliseconds. Default: 3600000 (1 hour).
JWT_EXPIRATION_MS=3600000

# Admin user credentials. Required. No defaults – the service will not start
# without these values.
ADMIN_USER=admin
ADMIN_PASS=password

# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=http://localhost:8501

# ---------------------------------------------------------------------------
# Auth – Python Agent
# ---------------------------------------------------------------------------
# Required. All /admin/* endpoints on the Python agent are protected by this
# key. Clients must supply it as the X-Admin-Api-Key request header.
# Generate a strong value with:  openssl rand -hex 32
ADMIN_API_KEY=27692fd0385ffdb5013324d91a09e1f66a599ed345c1e410effe190b06d2e85d

# ---------------------------------------------------------------------------
# OLLAMA_BASE_URL – set this based on your deployment mode:
#
#   Windows + NVIDIA GPU (Ollama in Docker):
#     OLLAMA_BASE_URL=http://ollama:11434
#     → Use: make up-gpu
#
#   Mac + Docker CPU (Ollama in Docker, no GPU):
#     OLLAMA_BASE_URL=http://ollama:11434
#     → Use: make up-mac-docker
#
#   Mac + Local Ollama (Ollama running natively with `ollama serve`):
#     OLLAMA_BASE_URL=http://host.docker.internal:11434
#     → Use: make up-mac-local
#       Note: host.docker.internal resolves to your Mac's host from inside
#       a Docker container. No value needed here; this is the default in
#       docker-compose.yml when OLLAMA_BASE_URL is not set.
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=

GENERAL_MODEL=llama3.1:8b
CODE_MODEL=qwen2.5-coder:7b
EMBEDDING_MODEL=nomic-embed-text


WEB_SEARCH_ENABLED=true
# Docker MCP gateway + DuckDuckGo defaults.
MCP_TRANSPORT=stdio
MCP_SERVER_COMMAND=docker
MCP_SERVER_ARGS=mcp gateway run --servers duckduckgo --secrets /.env
MCP_WEB_SEARCH_TOOL=search