SPRING_PROFILES_ACTIVE=default

AGENT_BASE_URL=http://python-agent:8000

MONGO_URI=mongodb://mongo:27017
MONGO_DB=engineering_copilot

# ---------------------------------------------------------------------------
# OLLAMA_BASE_URL – set this based on your deployment mode:
#
#   Windows + NVIDIA GPU (Ollama in Docker):
#     OLLAMA_BASE_URL=http://ollama:11434
#     → Use: make up-gpu
#
#   Mac + Docker CPU (Ollama in Docker, no GPU):
#     OLLAMA_BASE_URL=http://ollama:11434
#     → Use: make up-mac-docker
#
#   Mac + Local Ollama (Ollama running natively with `ollama serve`):
#     OLLAMA_BASE_URL=http://host.docker.internal:11434
#     → Use: make up-mac-local
#       Note: host.docker.internal resolves to your Mac's host from inside
#       a Docker container. No value needed here; this is the default in
#       docker-compose.yml when OLLAMA_BASE_URL is not set.
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434

GENERAL_MODEL=llama3.1:8b
CODE_MODEL=qwen2.5-coder:7b
EMBEDDING_MODEL=nomic-embed-text


WEB_SEARCH_ENABLED=true
MCP_TRANSPORT=stdio
MCP_SERVER_COMMAND=docker
MCP_SERVER_ARGS=mcp gateway run --servers duckduckgo --secrets /.env
MCP_WEB_SEARCH_TOOL=search